[Unit]
Description=FTS-Tunnel UDP 7100
Documentation=https://github.com/fantunelstore/fts-tunnel
After=syslog.target network-online.target

[Service]
User=root
NoNewPrivileges=true
ExecStart=/usr/local/fts/udp-mini --listen-addr 127.0.0.1:7100 --max-clients 500
Restart=on-failure
RestartPreventExitStatus=23
LimitNPROC=10000
LimitNOFILE=1000000
MemoryMax=100M

[Install]
WantedBy=multi-user.target