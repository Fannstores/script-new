[Unit]
Description=FTS-Tunnel WebSocket
Documentation=https://github.com/fantunelstore/fts-tunnel
After=syslog.target network-online.target

[Service]
User=root
NoNewPrivileges=true
ExecStart=/usr/bin/ws -f /usr/bin/tun.conf
Restart=on-failure
RestartPreventExitStatus=23
LimitNPROC=10000
LimitNOFILE=1000000
MemoryMax=100M

[Install]
WantedBy=multi-user.target
